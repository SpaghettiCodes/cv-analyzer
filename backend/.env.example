# OpenAI / OpenAI-compatible API
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# MONGODB (Docker Compose sets MONGODB_URI automatically)
MONGODB_URI=mongodb://admin:password@mongo:27017/experian?authSource=admin

# Atlas fallback when MONGODB_URI is unset
DB_USER=MongoDB_User
DB_PASSWORD=MongoDB_Password

FLASK_ENV=development
FLASK_APP=flaskr/index.py
